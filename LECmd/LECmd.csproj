<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <AssemblyTitle>LECmd</AssemblyTitle>
    <Company>Eric Zimmerman</Company>
    <LangVersion>10</LangVersion>
    <Product>LECmd</Product>
    <Description>Lnk Explorer Command line edition</Description>
    <Copyright>Eric Zimmerman</Copyright>
    <Version>2026.5.0</Version>
    <TargetFrameworks>net472;net9.0</TargetFrameworks>
    <Title>LECmd</Title>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup>
    <ApplicationIcon>PcDesktopCheck.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="AlphaFS.New" Version="2.3.0" />  
    <PackageReference Include="GuidMapping" Version="2026.5.0" />  
    <PackageReference Include="System.CommandLine" Version="2.0.8" />
  </ItemGroup>
  <ItemGroup>
    <Compile Update="Properties\Resources.Designer.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>Resources.resx</DependentUpon>
    </Compile>
  </ItemGroup>
  <ItemGroup>
    <Content Include="PcDesktopCheck.ico" />
    <None Include="Resources\style.css" />
    <None Include="Resources\normalize.css" />
    <None Include="Resources\MACs.txt" />
  </ItemGroup>
  <ItemGroup> 
    <PackageReference Include="Costura.Fody" Version="6.1.0">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Fody" Version="6.9.3">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CsvHelper" Version="33.1.0" />
    <PackageReference Include="Exceptionless" Version="6.1.0" />
    <PackageReference Include="ExtensionBlocks" Version="2026.5.0" />
    <PackageReference Include="Lnk" Version="2026.5.3" />
    <PackageReference Include="Serilog" Version="4.3.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.1.1" />
    <PackageReference Include="ServiceStack.Text" Version="10.0.6" />
  </ItemGroup>
</Project>
